"use client";

import { Contract, JsonRpcProvider, formatUnits } from "ethers";
import { useEffect, useMemo, useState } from "react";
import {
  RPC_URL,
  CHAIN_ID,
  PRESALE_VESTING_ADDRESS,
  REWARDPOOL_ADDRESS,
  DDC_TOKEN_ADDRESS,
} from "@/app/config/contracts";
import { DDC_PRESALE_ABI } from "@/app/abi/ddcPresaleVesting";
import { ERC20_ABI } from "@/app/abi/erc20";

type Data = {
  finalized?: boolean;
  finalizedBlock?: number;
  finalizedAt?: number;
  rewardPool?: string;
  unsoldMoved?: bigint;
  totalSold?: bigint;
  purchasesCount?: number;
};

type State =
  | { status: "idle" | "loading"; data?: undefined; error?: undefined }
  | { status: "success"; data: Data; error?: undefined }
  | { status: "error"; error: string; data?: undefined };

// Heuristika: iz Purchased log args izaberi "najverovatniji" DDC iznos.
// U praksi presale obično emituje (buyer, usdtAmount, ddcAmount, batchId) ili slično.
// Mi biramo najveći bigint arg (osim batchId koji je obično mali).
function pickLikelyDDCAmount(args: any): bigint | null {
  if (!args) return null;
  const candidates: bigint[] = [];
  for (const v of Object.values(args)) {
    if (typeof v === "bigint") candidates.push(v);
  }
  if (candidates.length === 0) return null;
  // filtriraj "male" vrednosti (batchId), uzmi maksimum
  const filtered = candidates.filter((x) => x > 10_000n); // prag da odbaci batchId
  const arr = filtered.length ? filtered : candidates;
  return arr.reduce((a, b) => (b > a ? b : a), arr[0]);
}

export default function PresaleFinalizeStatus() {
  const [st, setSt] = useState<State>({ status: "idle" });

  const provider = useMemo(() => new JsonRpcProvider(RPC_URL, CHAIN_ID), []);
  const presaleAddr = PRESALE_VESTING_ADDRESS as string;
  const rewardPoolAddr = (REWARDPOOL_ADDRESS as string) || "0x0000000000000000000000000000000000000000";
  const ddcAddr = DDC_TOKEN_ADDRESS as string;

  useEffect(() => {
    let alive = true;

    const run = async () => {
      try {
        if (!presaleAddr || presaleAddr === "0x0000000000000000000000000000000000000000") {
          setSt({ status: "error", error: "Presale adresa nije podešena (NEXT_PUBLIC_PRESALE_ADDRESS)." });
          return;
        }
        if (!rewardPoolAddr || rewardPoolAddr === "0x0000000000000000000000000000000000000000") {
          setSt({ status: "error", error: "RewardPool adresa nije podešena (NEXT_PUBLIC_REWARDPOOL_ADDRESS)." });
          return;
        }
        if (!ddcAddr || ddcAddr === "0x0000000000000000000000000000000000000000") {
          setSt({ status: "error", error: "DDC token adresa nije podešena (NEXT_PUBLIC_DDC_TOKEN_ADDRESS)." });
          return;
        }

        setSt({ status: "loading" });

        const presale: any = new Contract(presaleAddr, DDC_PRESALE_ABI, provider);
        const token: any = new Contract(ddcAddr, ERC20_ABI, provider);

        // 1) Finalize status: PresaleFinished event
        let finalized = false;
        let finalizedBlock: number | undefined;
        let finalizedAt: number | undefined;

        try {
          const logs = await presale.queryFilter(presale.filters.PresaleFinished?.(), 0, "latest");
          if (logs && logs.length) {
            finalized = true;
            const last = logs[logs.length - 1];
            finalizedBlock = Number(last.blockNumber);
            const b = await provider.getBlock(last.blockNumber);
            finalizedAt = b?.timestamp ? Number(b.timestamp) : undefined;
          }
        } catch {
          // ako event filter nije dostupan na ovoj instanci, ostavi kao —
        }

        // 2) Total sold: sum Purchased events (heuristika za DDC amount iz args)
        let totalSold = 0n;
        let purchasesCount = 0;

        try {
          const logs = await presale.queryFilter(presale.filters.Purchased?.(), 0, "latest");
          purchasesCount = logs?.length ?? 0;
          if (logs && logs.length) {
            for (const l of logs) {
              const amt = pickLikelyDDCAmount(l.args);
              if (amt) totalSold += amt;
            }
          }
        } catch {
          // ignore
        }

        // 3) Unsold moved: sum Transfer(presale -> rewardPool) on DDC token
        // Ovo hvata i finalize transfer(e), i eventualne dodatne transfere.
        let unsoldMoved = 0n;
        try {
          const logs = await token.queryFilter(token.filters.Transfer?.(presaleAddr, rewardPoolAddr), 0, "latest");
          if (logs && logs.length) {
            for (const l of logs) {
              const v = l.args?.value;
              if (typeof v === "bigint") unsoldMoved += v;
              else if (v?.toString) unsoldMoved += BigInt(v.toString());
            }
          }
        } catch {
          // ignore
        }

        const data: Data = {
          finalized,
          finalizedBlock,
          finalizedAt,
          rewardPool: rewardPoolAddr,
          unsoldMoved: unsoldMoved === 0n ? 0n : unsoldMoved,
          totalSold: purchasesCount ? totalSold : 0n,
          purchasesCount,
        };

        if (!alive) return;
        setSt({ status: "success", data });
      } catch (e: any) {
        if (!alive) return;
        setSt({ status: "error", error: e?.message ?? "Presale finalize read error" });
      }
    };

    run();
    const t = setInterval(run, 15000);
    return () => {
      alive = false;
      clearInterval(t);
    };
  }, [provider, presaleAddr, rewardPoolAddr, ddcAddr]);

  const fmt = (v?: bigint) => (typeof v === "bigint" ? formatUnits(v, 18) : "—");
  const fmtTs = (ts?: number) => (typeof ts === "number" && ts > 0 ? new Date(ts * 1000).toLocaleString() : "—");

  return (
    <div className="mt-6">
      <div className="mb-2">
        <h3 className="text-lg font-semibold">Presale finalize status</h3>
        <p className="text-sm opacity-80">Read-only on-chain finalize / unsold → RewardPool.</p>
      </div>

      <div className="border rounded p-4">
        {st.status === "idle" && <div className="text-sm opacity-80">—</div>}
        {st.status === "loading" && <div className="text-sm">Učitavanje…</div>}
        {st.status === "error" && <div className="text-sm text-red-600">{st.error}</div>}

        {st.status === "success" && (
          <div className="text-sm">
            <div className="flex items-center justify-between py-1">
              <span className="opacity-80">Finalized</span>
              <span className="font-semibold">{st.data.finalized ? "Yes" : "No"}</span>
            </div>

            <div className="flex items-center justify-between py-1">
              <span className="opacity-80">Finalized at</span>
              <span className="font-semibold">{fmtTs(st.data.finalizedAt)}</span>
            </div>

            <div className="flex items-center justify-between py-1">
              <span className="opacity-80">RewardPool</span>
              <span className="font-semibold">{st.data.rewardPool ?? "—"}</span>
            </div>

            <div className="flex items-center justify-between py-1">
              <span className="opacity-80">Unsold moved (ERC20 Transfer)</span>
              <span className="font-semibold">{fmt(st.data.unsoldMoved)}</span>
            </div>

            <div className="flex items-center justify-between py-1">
              <span className="opacity-80">Total sold (from Purchased events)</span>
              <span className="font-semibold">{fmt(st.data.totalSold)}</span>
            </div>

            <div className="flex items-center justify-between py-1">
              <span className="opacity-80">Purchases (events)</span>
              <span className="font-semibold">{st.data.purchasesCount ?? 0}</span>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
EOF
