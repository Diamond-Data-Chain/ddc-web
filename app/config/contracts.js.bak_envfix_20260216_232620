// app/config/contracts.js (env-first, runtime-safe)
// NOTE: kept for compatibility because some imports resolve to .js.

import { BrowserProvider, JsonRpcProvider } from "ethers";

const envStr = (k, d = "") => {
  const v = process.env[k];
  return (typeof v === "string" && v.length > 0) ? v : d;
};
const envNum = (k, d = 0) => {
  const v = process.env[k];
  const n = Number(v);
  return Number.isFinite(n) && n > 0 ? n : d;
};

export const HARDHAT_RPC_URL = "http://127.0.0.1:8545";
export const HARDHAT_CHAIN_ID = 31337;
export const HARDHAT_CHAIN_NAME = "DDC Local Testnet (Hardhat)";

export const RPC_URL = envStr("NEXT_PUBLIC_RPC_URL", HARDHAT_RPC_URL);
export const CHAIN_ID = envNum("NEXT_PUBLIC_CHAIN_ID", HARDHAT_CHAIN_ID);
export const CHAIN_NAME = envStr("NEXT_PUBLIC_CHAIN_NAME", HARDHAT_CHAIN_NAME);
export const BLOCK_EXPLORER_URL = envStr("NEXT_PUBLIC_BLOCK_EXPLORER_URL", "");

export const PRESALE_VESTING_ADDRESS = envStr("NEXT_PUBLIC_PRESALE_ADDRESS", "0x0000000000000000000000000000000000000000");
export const DDC_TOKEN_ADDRESS = envStr("NEXT_PUBLIC_DDC_TOKEN_ADDRESS", "0x0000000000000000000000000000000000000000");
export const USDT_MOCK_ADDRESS = envStr("NEXT_PUBLIC_USDT_ADDRESS", "0x0000000000000000000000000000000000000000");
export const GOVERNANCE_ADDRESS = envStr("NEXT_PUBLIC_GOVERNANCE_ADDRESS", "0x0000000000000000000000000000000000000000");
export const REWARDPOOL_ADDRESS = envStr("NEXT_PUBLIC_REWARDPOOL_ADDRESS", "0x0000000000000000000000000000000000000000");

export const ADDRESSES = {
  presale: PRESALE_VESTING_ADDRESS,
  ddc: DDC_TOKEN_ADDRESS,
  usdt: USDT_MOCK_ADDRESS,
  governance: GOVERNANCE_ADDRESS,
  rewardPool: REWARDPOOL_ADDRESS,
};

export const getReadonlyProvider = () => new JsonRpcProvider(RPC_URL);

export const getBrowserProvider = () => {
  if (typeof window === "undefined") return null;
  const eth = window.ethereum;
  if (!eth?.request) return null;
  return new BrowserProvider(eth);
};
