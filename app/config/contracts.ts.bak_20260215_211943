import { BrowserProvider, JsonRpcSigner, JsonRpcProvider } from "ethers";

/**
 * Jedini izvor istine za chain + adrese (env-first).
 * Ne brišemo legacy exporte da ne polomimo postojeće importe.
 */

const env = (key: string, fallback: string) => {
  const v = process.env[key];
  return v && v.trim().length > 0 ? v : fallback;
};
const envAny = (keys: string[], fallback: string) => {
  for (const k of keys) {
    const v = process.env[k];
    if (v && v.trim().length > 0) return v;
  }
  return fallback;
};
const envNum = (key: string, fallback: number) => {
  const v = process.env[key];
  const n = v ? Number(v) : NaN;
  return Number.isFinite(n) ? n : fallback;
};

