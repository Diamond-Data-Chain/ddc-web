// Provider helpers
type Eip1193Provider = { request: (args: { method: string; params?: unknown[] }) => Promise<unknown> };

export const getBrowserProvider = (): BrowserProvider | null => {
  const eth = (globalThis as unknown as { ethereum?: Eip1193Provider }).ethereum;
  if (!eth?.request) return null;
  return new BrowserProvider(eth as unknown);
};

export const getSigner = async (): Promise<JsonRpcSigner | null> => {
  const p = getBrowserProvider();
  if (!p) return null;
  return await p.getSigner();
};

// Readonly provider (bez wallet-a)
export const getReadonlyProvider = (): JsonRpcProvider => {
  return new JsonRpcProvider(RPC_URL, CHAIN_ID);
};
