      // Pokušaj native buy funkcija koje se najčešće koriste:
      const c: unknown = presaleWrite;

      let tx: import("ethers").ContractTransactionResponse | null = null;

      if (typeof (c as { buyWithNative?: Function }).buyWithNative === "function") {
        tx = await (c as { buyWithNative: Function }).buyWithNative(batchId ?? 1, { value: ethValue });
      } else {
        setTxStatus("Native buy function not found on presale contract.");
        setLastTxStatus("Buy failed ❌ no native buy fn");
        return;
      }

      setLastTxHash(tx?.hash ?? null);
      setLastTxStatus("Pending...");
      setLastTxBlock(null);

      const receipt = await tx!.wait();
      setLastTxStatus("Confirmed ✅");
      setLastTxBlock(Number(receipt?.blockNumber));

      setTxStatus("BNB buy confirmed ✅");
      await new Promise((r) => setTimeout(r, 300));

      await refreshData();
      await loadUsdtAllowance();
    } catch (e: unknown) {
      console.error("BNB buy error:", e);

      function getErrorMessage(err: unknown): string {
        if (typeof err === "object" && err !== null) {
          const maybeMsg = (prop: string) =>
            prop in err && typeof (err as Record<string, unknown>)[prop] === "string"
              ? (err as Record<string, unknown>)[prop] as string
              : undefined;
          const cause = "cause" in err && typeof (err as Record<string, unknown>)["cause"] === "object"
            ? (err as Record<string, unknown>)["cause"] as Record<string, unknown>
            : undefined;
          return (
            maybeMsg("shortMessage") ||
            maybeMsg("reason") ||
            maybeMsg("message") ||
            (cause && typeof cause === "object" && (
              (typeof cause["shortMessage"] === "string" && cause["shortMessage"]) ||
              (typeof cause["message"] === "string" && cause["message"])
            )) ||
            "BNB buy failed"
          );
        }
        return "BNB buy failed";
      }

      const msg = getErrorMessage(e);

      setTxStatus(`BNB buy failed ❌ ${msg}`);
      setLastTxStatus(`Buy failed ❌ ${msg}`);
    } finally {
      setLoading(false);
    }
  };

  const handleClaim = async () => {
    setLoading(true);
    setTxStatus(null);
    try {
      if (!isConnected || !address) {
        setTxStatus("Please connect a wallet to continue.");
        setLastTxStatus("Wallet not connected");
        return;
      }
      if (isWrongNetwork) {
        setTxStatus("Wrong network. Please switch to the configured network.");
        setLastTxStatus("Wrong network");
        return;
      }
      if (!presaleWrite) {
        setTxStatus("Wallet signer not available.");
        setLastTxStatus("No signer");
        return;
      }
      if (claimable === 0n) {
        setTxStatus("Nothing to claim.");
        setLastTxStatus("Nothing to claim");
        return;
      }

      const c: any = presaleWrite;
      const fnNames = ["claim", "claimDDC", "claimTokens", "claimVested"];
      let tx: any = null;

      for (const fn of fnNames) {
        if (typeof c?.[fn] === "function") {
          tx = await c[fn]();
          break;
        }
      }

      if (!tx) {
        setTxStatus("Claim function not found in contract ABI.");
        setLastTxStatus("Claim unavailable");
        return;
      }

      setLastTxHash(tx.hash || null);
      setTxStatus("Claim submitted…");
      setLastTxStatus("Pending…");

      const receipt = await tx.wait();
      setLastTxBlock(receipt?.blockNumber ?? null);

      setTxStatus("Claim confirmed ✅");
      setLastTxStatus("Claimed ✅");

      // refresh UI after claim
      await refreshData();
    } catch (e: any) {
      const msg = ddcErrMsg(e);
      console.error("Claim error:", e);
      setTxStatus(`Claim failed: ${msg}`);
      setLastTxStatus(`Claim failed ❌ ${msg}`);
    } finally {
      setLoading(false);
    }
  };

  const handleAddToken = async () => {
    if (typeof window === "undefined") return;
    // Use the standard Ethereum provider type for better type safety
    interface EthereumProvider {
      request: (args: { method: string; params?: unknown }) => Promise<unknown>;
    }
    // Extend the Window interface to include ethereum
    const ethereum = (window as unknown as { ethereum?: EthereumProvider }).ethereum;
    if (!ethereum) {
      alert("MetaMask nije pronađen.");
      return;
    }

    try {
      const wasAdded = await ethereum.request({
        method: "wallet_watchAsset",
        params: {
          type: "ERC20",
          options: {
            address: DDC_TOKEN_ADDRESS,
            symbol: "DDC",
            decimals: 18,
          },
        },
      });

      if (wasAdded) {
        alert("DDC coin je dodat u wallet.");
      } else {
        alert("Dodavanje DDC coina je otkazano.");
      }
    } catch (err) {
      console.error("Greška pri dodavanju DDC tokena:", err);
      alert("Nešto nije u redu pri dodavanju DDC coina (vidi konzolu).");
    }
  };

  const sold = batch?.soldDDC ?? 0n;
  const hardCap = batch?.hardCapDDC ?? 0n;
  const remaining = hardCap > sold ? hardCap - sold : 0n;
  const progress =
    hardCap > 0n ? Number((sold * 10000n) / hardCap) / 100 : 0;

  const currentPlan =
    batchId && batchId >= 1 && batchId <= TOTAL_BATCHES
      ? PRESALE_PLAN[batchId - 1]
      : null;

  // ⏱️ Izračun brojača: trajanje batch-a i vreme do kraja
  let batchDurationHours: string = "102.4"; // default ako kontrakt ne vrati ništa
  let timeLeftLabel: string | null = null;

  useEffect(() => {
    if (!batchId) return;

    if (batchStart > 0n && batchEnd > batchStart) {
      if (lazyBatchAnchorTs !== null || lazyBatchAnchorId !== null) {
        setLazyBatchAnchorTs(null);
        setLazyBatchAnchorId(null);
      }
      return;
    }

    if (batchStart === 0n && batchEnd === 0n && nowTs > 0) {
      if (lazyBatchAnchorId !== batchId) {
        setLazyBatchAnchorId(batchId);
        setLazyBatchAnchorTs(nowTs);
      } else if (lazyBatchAnchorTs == null) {
        setLazyBatchAnchorTs(nowTs);
      }
    }
  }, [batchId, batchStart, batchEnd, nowTs, lazyBatchAnchorTs, lazyBatchAnchorId]);

  const EXPECTED_BATCH_DURATION_SEC = 368640; // 102.4h

  // Lazy rollover: currentBatch() may already point to the next batch,
  // while batchInfo(next) still has start/end=0 until the next write tx.
  const effectiveBatchStart =
    batchStart > 0n
      ? batchStart
      : lazyBatchAnchorTs != null && batchId != null && batchId >= 1 && batchId <= TOTAL_BATCHES
      ? BigInt(lazyBatchAnchorTs)
      : 0n;

  const effectiveBatchEnd =
    batchEnd > effectiveBatchStart
      ? batchEnd
      : effectiveBatchStart > 0n
      ? effectiveBatchStart + BigInt(EXPECTED_BATCH_DURATION_SEC)
      : 0n;

  const actualBatchDurationSec =
    effectiveBatchStart > 0n && effectiveBatchEnd > effectiveBatchStart
      ? Number(effectiveBatchEnd - effectiveBatchStart)
      : null;

  const durationRulesOk = actualBatchDurationSec === EXPECTED_BATCH_DURATION_SEC;
  const rolloverRulesOk =
    batchId == null ||
    batchId >= TOTAL_BATCHES ||
    effectiveBatchEnd === 0n ||
    nowTs === 0 ||
    nowTs < Number(effectiveBatchEnd);

  const batchRulesOk = durationRulesOk && rolloverRulesOk;
  const batchRulesLabel = batchRulesOk ? "YES" : "NO";
  const batchRulesNote = !durationRulesOk
    ? `duration=${actualBatchDurationSec ?? "-"}s, expected=368640s`
    : !rolloverRulesOk
    ? "batch end passed; should auto-roll"
    : batchStart === 0n && batchEnd === 0n
    ? "lazy rollover UI timer active"
    : "102.4h + active timing OK";

  if (effectiveBatchStart > 0n && effectiveBatchEnd > effectiveBatchStart) {
    try {
      const start = Number(effectiveBatchStart);
      const end = Number(effectiveBatchEnd);
      const durSec = Math.max(0, end - start);
      if (durSec > 0) batchDurationHours = (durSec / 3600).toFixed(1);

      if (end > start) {
        const now = Math.max(nowTs, start);
        if (now < start) {
          timeLeftLabel = "Batch not started yet";
        } else if (now >= end) {
          timeLeftLabel = "Batch ended";
        } else {
          const rem = end - now;
          const days = Math.floor(rem / 86400);
          const h = Math.floor((rem % 86400) / 3600);
          const m = Math.floor((rem % 3600) / 60);
          const s = rem % 60;

          const hh = h.toString().padStart(2, "0");
          const mm = m.toString().padStart(2, "0");
          const ss = s.toString().padStart(2, "0");

          if (days > 0) {
            timeLeftLabel = `${days}d ${hh}:${mm}:${ss}`;
          } else {
            timeLeftLabel = `${hh}:${mm}:${ss}`;
          }
        }
      }
    } catch {
      // ostavi default 102.4h i "-" za timeLeftLabel
    }
  }

  return (
    <section id="presale" className="relative z-10 mx-auto max-w-5xl space-y-10 rounded-3xl border border-amber-400/40 bg-black/40 p-8 shadow-[0_0_40px_rgba(251,191,36,0.25)] backdrop-blur">
      {/* Gornji header */}
      <div className="flex flex-col justify-between gap-4 md:flex-row md:items-center">
        <div>
          <h2 className="text-xl font-semibold tracking-wide text-amber-200">
            DDC Presale – Dashboard
          </h2>
          <p className="text-sm text-amber-100/70">
            Batch #{batchId ?? "-"} / {TOTAL_BATCHES} · DDC Local Testnet
            (Hardhat)
          </p>
          <p className="text-[11px] text-amber-100/60 mt-1">
            Network:{" "}
            <span className={isConnected ? "text-emerald-300" : "text-amber-200"}>
              {isConnected ? "Wallet connected" : "Not connected"}
            </span>
          </p>
          <p className="text-[11px] text-amber-100/60">
            Chain ID: <span className="font-semibold">{chainId ?? "-"}</span>
          </p>
          {currentPlan && (
            <p className="mt-1 text-xs text-amber-100/70">
              Planned price for this batch:{" "}
              <span className="font-semibold">
                {currentPlan.priceUSDT.toFixed(2)} USDT
              </span>{" "}
              per DDC · Batch size (on-chain):{" "}
              <span className="font-semibold">
                {hardCap > 0n ? formatBigInt(hardCap) : "-"} DDC
              </span>
            </p>
          )}
        </div>
        <div className="flex gap-3">
          <button
            onClick={handleConnect}
            className="rounded-full border border-amber-400/60 bg-amber-500/10 px-4 py-2 text-xs font-medium text-amber-100 hover:bg-amber-500/20"
          >
            {isConnected && address
              ? `Wallet: ${address.slice(0, 6)}…${address.slice(-4)}`
              : "Connect Wallet"}
          </button>

          <button
            onClick={handleAddNetwork}
            className="rounded-full border border-amber-300/60 bg-amber-300/10 px-4 py-2 text-xs font-medium text-amber-100 hover:bg-amber-300/20"
          >
            Add DDC Network
          </button>

          <button
            onClick={handleAddToken}
            className="rounded-full border border-emerald-300/60 bg-emerald-300/10 px-4 py-2 text-xs font-medium text-emerald-100 hover:bg-emerald-300/20"
          >
            Add DDC Coin
          </button>
        </div>
      </div>

      {/* ➤ BATCH PROGRESS LINE (sa pulsiranjem na kraju) */}
      <div className="relative mt-4 h-2 w-full overflow-hidden rounded-full bg-amber-500/20">
        <div
          className={`
            h-full rounded-full transition-all duration-500
            ${
              progress >= 95
                ? "bg-red-500 animate-pulse"
                : progress >= 80
                ? "bg-orange-400 animate-pulse"
                : "bg-amber-400"
            }
          `}
          style={{ width: `${progress}%` }}
        />
      </div>

      <p className="text-right text-[11px] text-amber-100/70 mt-1">
        {progress.toFixed(2)}% of batch sold
      </p>

      {/* Glavna mreža kartica */}
      <div className="grid gap-6 md:grid-cols-3">
        {/* Batch status */}
        <div className="rounded-2xl border border-amber-500/40 bg-black/40 p-5 shadow-lg transition-transform hover:-translate-y-0.5 hover:shadow-amber-400/40">
          <h3 className="mb-3 text-sm font-semibold text-amber-200">
            Current Batch Status
          </h3>
          {lastReadError && (
            <div className="mt-2 rounded-xl border border-red-900/60 bg-red-950/30 p-3 text-xs text-red-200">
              Read error: {lastReadError}
            </div>
          )}
<div className="space-y-1 text-xs text-amber-100/80">
            <div className="flex justify-between">
              <span>Batch ID</span>
              <span>#{batchId ?? "-"}</span>
            </div>
            <div className="flex justify-between">
              <span>Hard cap</span>
              <span>{formatBigInt(hardCap)} DDC</span>
            </div>
            <div className="flex justify-between">
              <span>Sold</span>
              <span>{formatBigInt(sold)} DDC</span>
            </div>
            <div className="flex justify-between">
              <span>Remaining</span>
              <span>{formatBigInt(remaining)} DDC</span>
            </div>

            {/* ⏱️ Dodati brojači za batch */}
            <div className="flex justify-between">
              <span>Batch duration</span>
              <span>{batchDurationHours} h</span>
            </div>
            <div className="flex justify-between">
              <span>Time left in batch</span>
              <span>{timeLeftLabel ?? "-"}</span>
            </div>
            <div className="flex justify-between">
              <span>Batch rules</span>
              <span className={batchRulesOk ? "text-emerald-300" : "text-red-300"}>
                {batchRulesLabel}
              </span>
            </div>
            <div className="flex justify-between">
              <span>Rules note</span>
              <span className="max-w-[60%] text-right">{batchRulesNote}</span>
            </div>

            <div className="flex justify-between">
              <span>Current batch price (USDT per DDC)</span>
              <span>
                {batch
                  ? `${formatPriceUSDT(batch!.priceInUSDT, usdtDecimals)} USDT`
                  : "-"}
              </span>
            </div>
          </div>
          <div className="mt-3 h-2 w-full overflow-hidden rounded-full bg-amber-500/20">
            <div
              className="h-full rounded-full bg-gradient-to-r from-amber-300 via-amber-400 to-amber-500"
              style={{ width: `${progress}%` }}
            />
          </div>
          <p className="mt-1 text-right text-[10px] text-amber-100/70">
            {progress.toFixed(2)}% sold
          </p>
        </div>

              {batch?.priceInUSDT && (
                (() => {
                  const out = calcYouWillGetDDC(amountUSDT, batch!.priceInUSDT, remaining);
                  // Always render action buttons; use disabled state instead of hiding.
// if (!amountUSDT || amountUSDT === "0" || out.ddc === 0n) return null;

                  return (
                    <div className="mt-2 rounded-lg border border-amber-500/20 bg-black/30 px-3 py-2">
                      <p className="text-xs text-amber-100/80">
                        You will get{" "}
                        <span className="font-semibold text-amber-100">
                          {formatDDC(out.ddc)} DDC
                        </span>
                      </p>
                      <p className="mt-0.5 text-[11px] text-amber-100/60">
                        at{" "}
                        <span className="font-medium text-amber-100">
                          {formatUnits(batch!.priceInUSDT, usdtDecimals)} USDT / DDC
                        </span>{" "}
                        (current batch price)
                      </p>
                      {out.isCapped && (
                        <p className="mt-1 text-[11px] text-amber-200/80">
                          capped to remaining supply
                        </p>
                      )}
                    </div>
                  );
                })()
              )}

              {(() => {
                const needed = parseUnits(amountUSDT || "0", usdtDecimals);
                const canProceed = needed > 0n;
                const hasAllowance = usdtAllowance >= needed;

                return (
                  <div className="mt-4 grid grid-cols-2 gap-2">
                    <button
                      onClick={handleApproveUSDT}
                      disabled={loading || !isConnected || isWrongNetwork || !canProceed}
                      className="w-full rounded-full bg-blue-500/90 px-4 py-3 text-sm font-semibold text-black shadow-xl hover:brightness-110 disabled:cursor-not-allowed disabled:opacity-50"
                    >
                      Approve USDT
                    </button>

                    <button
                      onClick={handleBuyWithUSDT}
                      disabled={
                        loading ||
                        !isConnected ||
                        isWrongNetwork ||
                        !canProceed ||
                        !hasAllowance ||
                        !batchId
                      }
                      className="w-full rounded-full bg-emerald-500/90 px-4 py-3 text-sm font-semibold text-black shadow-xl hover:brightness-110 disabled:cursor-not-allowed disabled:opacity-50"
                    >
                      Buy with USDT
                    </button>
                  </div>
                );
              })()}
            </>
          )}

          {txStatus && (
            <p className="mt-3 text-[11px] text-amber-100/80">{txStatus}</p>
          )}
        </div>
      </div>

      {/* TX Log */}
      {lastTxHash && (
        <div className="rounded-2xl border border-amber-500/40 bg-black/30 p-4 text-xs text-amber-100/80">
          <div className="flex flex-col gap-1">
            <div className="flex items-start justify-between gap-3">
              <div className="min-w-0">
                <span className="text-amber-200 font-semibold">Last TX:</span>{" "}
                <span className="font-mono break-all">{lastTxHash}</span>
              </div>

              <button
                className="shrink-0 rounded-lg border border-amber-400/40 bg-amber-500/10 px-2 py-1 text-[11px] text-amber-100 hover:bg-amber-500/20"
                onClick={() => navigator.clipboard.writeText(lastTxHash)}
              >
                Copy
              </button>
            </div>
            <div>
              <span className="text-amber-200 font-semibold">Status:</span>{" "}
              {lastTxStatus ?? "-"}
            </div>
            <div>
              <span className="text-amber-200 font-semibold">Block:</span>{" "}
              {lastTxBlock ?? "-"}
            </div>
          </div>
        </div>
      )}

      {/* TABELA: svih 40 batcheva i cene */}
      <div className="rounded-2xl border border-amber-500/40 bg-black/30 p-5 shadow-inner">
        <h3 className="mb-3 text-sm font-semibold text-amber-200">
          Presale Structure – 40 Batches
        </h3>
        <p className="mb-3 text-[11px] text-amber-100/80">
          Each batch has{" "}
          <span className="font-semibold">
            {BATCH_SIZE_DDC.toLocaleString("en-US")} DDC
          </span>
          . Početna cena je{" "}
          <span className="font-semibold">0.01 USDT</span> per DDC, and each
          sledeći batch je skuplji za{" "}
          <span className="font-semibold">0.02 USDT</span>.
        </p>
        <div className="overflow-x-auto">
          <table className="min-w-full text-xs text-left text-amber-50/90">
            <thead className="border-b border-amber-500/40 text-[10px] uppercase tracking-wide text-amber-200/80">
              <tr>
                <th className="py-2 pr-4">Batch</th>
                <th className="py-2 pr-4">DDC per batch</th>
                <th className="py-2 pr-4">Price / DDC (USDT)</th>
                <th className="py-2 pr-4">Total raise (USDT)</th>
              </tr>
            </thead>
            <tbody>
              {PRESALE_PLAN.map((b) => {
                const totalRaise = b.priceUSDT * b.supplyDDC;
                return (
                  <tr
                    key={b.id}
                    className="border-b border-amber-500/10 last:border-0"
                  >
                    <td className="py-1.5 pr-4 font-mono text-amber-100">
                      #{b.id}
                    </td>
                    <td className="py-1.5 pr-4">
                      {b.supplyDDC.toLocaleString("en-US")} DDC
                    </td>
                    <td className="py-1.5 pr-4">
                      {b.priceUSDT.toFixed(2)} USDT
                    </td>
                    <td className="py-1.5 pr-4">
                      {totalRaise.toLocaleString("en-US", {
                        maximumFractionDigits: 2,
                      })}{" "}
                      USDT
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    
      <RewardPoolStatus />

      <PresaleFinalizeStatus />
presaleRead.totalPurchased(address),
presaleRead.claimed(address),
</section>
  );
}
