function formatBigInt(value: unknown) {
  if (value === null || value === undefined) return "0";
  try {
    const bi = BigInt(value.toString());
    const asEth = Number(formatEther(bi));
    return asEth.toLocaleString("en-US", {
      maximumFractionDigits: 2,
    });
  } catch (e: any) {
      const msg = String(e?.shortMessage || e?.message || e);
      console.error('[presale-read] failed:', msg);
      setLastReadError(msg);

    return "0";
  }
}

function formatPriceUSDT(price: bigint | null | undefined, usdtDecimals?: number) {
  if (price == null) return "-";
  const dec = typeof usdtDecimals === "number" && usdtDecimals >= 0 ? usdtDecimals : 6;

  // exact string (e.g. "0.01")
  const s = formatUnits(price, dec);

  // If it's extremely small, show more precision instead of "0.00"
  const n = Number(s);
  if (!Number.isFinite(n)) return s;

  if (n > 0 && n < 0.01) {
    // show up to 18 decimals for tiny prices
    return n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 18 });
  }

  return n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 6 });
}

function toFixedNoSci(n: number, decimals = 6) {
  if (!Number.isFinite(n) || n <= 0) return "0";
  return n.toFixed(decimals).replace(/\.?0+$/, "");
}

// How much native coin is needed to buy exactly the remaining DDC (based on on-chain "priceInUSDT" logic)
// eslint-disable-next-line @typescript-eslint/no-unused-vars
function calcMaxEthToFillBatch(
  remainingDDC?: bigint | null,
  priceInUSDT?: bigint | null
) {
  if (!remainingDDC || !priceInUSDT) return "0";
  if (remainingDDC <= 0n || priceInUSDT <= 0n) return "0";

  const requiredWei = (remainingDDC * priceInUSDT) / 1000000000000000000n;
  if (requiredWei <= 0n) return "0";

  const eth = Number(formatEther(requiredWei));
  return toFixedNoSci(eth, 6);
}

function calcMaxUsdtToFillBatch(
  remainingDDC?: bigint | null,
  priceInUSDT?: bigint | null
) {
  if (!remainingDDC || !priceInUSDT) return "0";
  if (remainingDDC <= 0n || priceInUSDT <= 0n) return "0";

  const usdtNeeded = (remainingDDC * priceInUSDT) / 1000000000000000000n;
  if (usdtNeeded <= 0n) return "0";

  const usdt = Number(formatEther(usdtNeeded));
  return toFixedNoSci(usdt, 6);
}

function calcYouWillGetDDC(amountStr: string, priceInUSDT?: bigint | null, remaining?: bigint | null) {
  try {
    if (!priceInUSDT || priceInUSDT <= 0n) return { ddc: 0n, isCapped: false };
    const amt = parseUnits((amountStr || "0").replace(",", "."), 6);
    if (amt <= 0n) return { ddc: 0n, isCapped: false };

    let ddc = (amt * 1000000000000000000n) / priceInUSDT; // (amount * 1e18) / price
    let isCapped = false;

    if (remaining != null && remaining > 0n && ddc > remaining) {
      ddc = remaining;
      isCapped = true;
    }

    return { ddc, isCapped };
  } catch {
    return { ddc: 0n, isCapped: false };
  }
}


function ddcErrMsg(err: any): string {
  try {
    if (!err) return "Unknown error";
    if (typeof err === "string") return err;
    // ethers v6 style
    const sm = err.shortMessage || err.reason || err.message;
    if (sm) return String(sm);
    // Hardhat / RPC nested error
    const nested = err.error?.message || err.error?.reason;
    if (nested) return String(nested);
    return JSON.stringify(err);
  } catch {
    return "Unknown error";
  }
}

function formatDDC(ddc: bigint) {
  const num = Number(formatEther(ddc));
  if (!Number.isFinite(num)) return "0";
  return num.toLocaleString("en-US", { maximumFractionDigits: 6 });
}

