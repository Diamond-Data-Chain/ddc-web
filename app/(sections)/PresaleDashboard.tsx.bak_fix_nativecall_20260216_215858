            Network:{" "}
            <span className={isConnected ? "text-emerald-300" : "text-amber-200"}>
              {isConnected ? "Wallet connected" : "Not connected"}
            </span>
          </p>
          <p className="text-[11px] text-amber-100/60">
            Chain ID: <span className="font-semibold">{chainId ?? "-"}</span>
          </p>
          {currentPlan && (
            <p className="mt-1 text-xs text-amber-100/70">
              Planned price for this batch:{" "}
              <span className="font-semibold">
                {currentPlan.priceUSDT.toFixed(2)} USDT
              </span>{" "}
              per DDC · Batch size (on-chain):{" "}
              <span className="font-semibold">
                {hardCap > 0n ? formatBigInt(hardCap) : "-"} DDC
              </span>
            </p>
          )}
        </div>
        <div className="flex gap-3">
          <button
            onClick={handleConnect}
            className="rounded-full border border-amber-400/60 bg-amber-500/10 px-4 py-2 text-xs font-medium text-amber-100 hover:bg-amber-500/20"
          >
            {isConnected && address
              ? `Wallet: ${address.slice(0, 6)}…${address.slice(-4)}`
              : "Connect Wallet"}
          </button>

          <button
            onClick={handleAddNetwork}
            className="rounded-full border border-amber-300/60 bg-amber-300/10 px-4 py-2 text-xs font-medium text-amber-100 hover:bg-amber-300/20"
          >
            Add DDC Network
          </button>

          <button
            onClick={handleAddToken}
            className="rounded-full border border-emerald-300/60 bg-emerald-300/10 px-4 py-2 text-xs font-medium text-emerald-100 hover:bg-emerald-300/20"
          >
            Add DDC Coin
          </button>
        </div>
      </div>

      {/* ➤ BATCH PROGRESS LINE (sa pulsiranjem na kraju) */}
      <div className="relative mt-4 h-2 w-full overflow-hidden rounded-full bg-amber-500/20">
        <div
          className={`
            h-full rounded-full transition-all duration-500
            ${
              progress >= 95
                ? "bg-red-500 animate-pulse"
                : progress >= 80
                ? "bg-orange-400 animate-pulse"
                : "bg-amber-400"
            }
          `}
          style={{ width: `${progress}%` }}
        />
      </div>

      <p className="text-right text-[11px] text-amber-100/70 mt-1">
        {progress.toFixed(2)}% of batch sold
      </p>

      {/* Glavna mreža kartica */}
      <div className="grid gap-6 md:grid-cols-3">
        {/* Batch status */}
        <div className="rounded-2xl border border-amber-500/40 bg-black/40 p-5 shadow-lg transition-transform hover:-translate-y-0.5 hover:shadow-amber-400/40">
          <h3 className="mb-3 text-sm font-semibold text-amber-200">
            Current Batch Status
          </h3>
          <div className="space-y-1 text-xs text-amber-100/80">
            <div className="flex justify-between">
              <span>Batch ID</span>
              <span>#{batchId ?? "-"}</span>
            </div>
            <div className="flex justify-between">
              <span>Hard cap</span>
              <span>{formatBigInt(hardCap)} DDC</span>
            </div>
            <div className="flex justify-between">
              <span>Sold</span>
              <span>{formatBigInt(sold)} DDC</span>
            </div>
            <div className="flex justify-between">
              <span>Remaining</span>
              <span>{formatBigInt(remaining)} DDC</span>
            </div>

            {/* ⏱️ Dodati brojači za batch */}
            <div className="flex justify-between">
              <span>Batch duration</span>
              <span>{batchDurationHours} h</span>
            </div>
            <div className="flex justify-between">
              <span>Time left in batch</span>
              <span>{timeLeftLabel ?? "-"}</span>
            </div>

            <div className="flex justify-between">
              <span>Current batch price (USDT per DDC)</span>
              <span>
                {batch
                  ? `${formatPriceUSDT(batch.priceInUSDT, usdtDecimals)} USDT`
                  : "-"}
              </span>
            </div>
          </div>
          <div className="mt-3 h-2 w-full overflow-hidden rounded-full bg-amber-500/20">
            <div
              className="h-full rounded-full bg-gradient-to-r from-amber-300 via-amber-400 to-amber-500"
              style={{ width: `${progress}%` }}
            />
          </div>
          <p className="mt-1 text-right text-[10px] text-amber-100/70">
            {progress.toFixed(2)}% sold
          </p>
        </div>

        {false && (
          <div className="mt-3 rounded-2xl border border-amber-400/40 bg-amber-500/10 p-3">
            <div className="text-sm font-semibold text-amber-100">
              This batch is SOLD OUT
            </div>
            <div className="mt-1 text-xs text-amber-100/70">
              </div>
            <button
              onClick={async () => {
                await refreshData();
              }}
              className="mt-2 rounded-full bg-amber-500/90 px-4 py-2 text-xs font-semibold text-black hover:brightness-110"
            >
              Refresh
            </button>
          </div>
        )}

        {/* Tvoja alokacija */}
        <div className="rounded-2xl border border-amber-500/40 bg-black/40 p-5 shadow-lg transition-transform hover:-translate-y-0.5 hover:shadow-amber-400/40">
          <h3 className="mb-3 text-sm font-semibold text-amber-200">
            Your Allocation
          </h3>
          <div className="space-y-1 text-xs text-amber-100/80">
            <div className="flex justify-between">
              <span>Total purchased</span>
              <span>{formatBigInt(totalPurchased)} DDC</span>
            </div>
            <div className="flex justify-between">
              <span>Already claimed</span>
              <span>{formatBigInt(claimed)} DDC</span>
            </div>
            <div className="flex justify-between">
              <span>Still locked</span>
              <span>{formatBigInt(locked)} DDC</span>
            </div>
            <div className="flex justify-between text-emerald-300">
              <span>Claimable now</span>
              <span>{formatBigInt(claimable)} DDC</span>
            </div>
          </div>
          <button
            onClick={handleClaim}
            disabled={loading || claimable === 0n || !isConnected}
            className="mt-4 w-full rounded-full bg-emerald-500/90 px-4 py-2 text-xs font-semibold text-black shadow-lg shadow-emerald-500/40 hover:bg-emerald-400 disabled:cursor-not-allowed disabled:bg-emerald-500/40"
          >
            Claim DDC
          </button>
        </div>

        {/* Buy box */}
        <div className="rounded-2xl border border-amber-500/40 bg-black/40 p-5 shadow-lg transition-transform hover:-translate-y-0.5 hover:shadow-amber-400/40 md:col-span-1">
          <h3 className="mb-2 text-sm font-semibold text-amber-200">
            Buy DDC
          </h3>

          <select
            value={payMethod}
            onChange={(e) => setPayMethod(e.target.value as "ETH" | "USDT")}
            className="mb-3 w-full rounded-xl border border-amber-500/40 bg-black/60 px-3 py-2 text-sm text-amber-50 outline-none"
          >
            <option value="ETH">Pay with ETH</option>
            <option value="USDT">Pay with USDT</option>
          </select>

          {!isConnected && (
            <p className="mb-2 text-[11px] text-amber-100/60">
              Please connect your wallet first.
            </p>
          )}

          {/* ETH MODE */}
          {payMethod === "ETH" && (
            <>
              <label className="block text-[11px] text-amber-100/70">
                Amount in ETH
              </label>
              <input
                value={amountEth}
                onChange={(e) => setAmountEth(e.target.value.replace(",", "."))}
                className="mt-1 w-full rounded-xl border border-amber-500/40 bg-black/60 px-3 py-2 text-sm text-amber-50 outline-none focus:border-amber-300"
              />
              {batch && (
                (() => {
                  const out = calcYouWillGetDDC(amountEth, batch.priceInUSDT, remaining);

                  const raw = (amountEth || "").trim();
                  if (!raw || raw === "0" || raw === "0.") {
                    return (
                      <p className="mt-2 text-[11px] text-amber-100/60">
                        Enter amount to see estimation.
                      </p>
                    );
                  }

                  return (
                    <div className="mt-2 rounded-lg border border-amber-500/20 bg-black/30 px-3 py-2">
                      <p className="text-xs text-amber-100/80">
                        You will get{" "}
                        <span className="font-semibold text-amber-100">
                          {formatDDC(out.ddc)} DDC
                        </span>
                      </p>

                      <p className="mt-0.5 text-[11px] text-amber-100/60">
                        at{" "}
                        <span className="font-medium text-amber-100">
                          {batch?.priceInUSDT ? formatUnits(batch.priceInUSDT, usdtDecimals) : "-"} USDT / DDC
                        </span>{" "}
                        (current batch price)
                      </p>

                      {out.isCapped && (
                        <p className="mt-1 text-[11px] text-amber-200/80">
                          capped to remaining supply
                        </p>
                      )}
                    </div>
                  );
                })()
              )}

              {/* ETH BUY BUTTON — UBACENO OVDE */}
              <div className="mt-4 grid grid-cols-1 gap-2">
                <button
                  onClick={handleBuy}
                  disabled={
                    loading ||
                    !isConnected ||
                    isWrongNetwork ||
                    !(parseFloat(amountEth || "0") > 0)
                  }
                  className="w-full rounded-full bg-emerald-500/90 px-4 py-3 text-sm font-semibold text-black shadow-xl hover:brightness-110 disabled:cursor-not-allowed disabled:opacity-50"
                >
                  Buy with ETH
                </button>
              </div>
            </>
          )}

          {/* USDT MODE */}
          {payMethod === "USDT" && (
            <>
              <label className="block text-[11px] text-amber-100/70">
                Amount in USDT
              </label>
              <input
                value={amountUSDT}
                onChange={(e) => setAmountUSDT(e.target.value.replace(",", "."))}
                className="mt-1 w-full rounded-xl border border-amber-500/40 bg-black/60 px-3 py-2 text-sm text-amber-50 outline-none focus:border-amber-300"
                placeholder="e.g. 100"
              />

              <div className="mt-2 flex gap-2">
                <button
                  type="button"
                  onClick={() => {
                    const walletMax = Number(formatUnits(usdtBalance ?? 0n, usdtDecimals));
                    const batchMax =
                      batch && batch.priceInUSDT
                        ? Number(calcMaxUsdtToFillBatch(remaining, batch.priceInUSDT))
                        : walletMax;
                    const finalMax = Math.max(0, Math.min(walletMax, batchMax));
                    setAmountUSDT(finalMax > 0 ? finalMax.toString() : "0");
                  }}
                  className="rounded-full border border-amber-500/40 bg-amber-500/10 px-3 py-1 text-[11px] text-amber-100 hover:bg-amber-500/20"
                >
                  MAX
                </button>
              </div>

              {batch?.priceInUSDT && (
                (() => {
                  const out = calcYouWillGetDDC(amountUSDT, batch.priceInUSDT, remaining);
                  if (!amountUSDT || amountUSDT === "0" || out.ddc === 0n) return null;

                  return (
                    <div className="mt-2 rounded-lg border border-amber-500/20 bg-black/30 px-3 py-2">
                      <p className="text-xs text-amber-100/80">
                        You will get{" "}
                        <span className="font-semibold text-amber-100">
                          {formatDDC(out.ddc)} DDC
                        </span>
                      </p>
                      <p className="mt-0.5 text-[11px] text-amber-100/60">
                        at{" "}
                        <span className="font-medium text-amber-100">
                          {formatUnits(batch.priceInUSDT, usdtDecimals)} USDT / DDC
                        </span>{" "}
                        (current batch price)
                      </p>
                      {out.isCapped && (
                        <p className="mt-1 text-[11px] text-amber-200/80">
                          capped to remaining supply
                        </p>
                      )}
                    </div>
                  );
                })()
              )}

              {(() => {
                const needed = parseUnits(amountUSDT || "0", usdtDecimals);
                const canProceed = needed > 0n;
                const hasAllowance = usdtAllowance >= needed;

                return (
                  <div className="mt-4 grid grid-cols-2 gap-2">
                    <button
                      onClick={handleApproveUSDT}
                      disabled={loading || !isConnected || isWrongNetwork || !canProceed}
                      className="w-full rounded-full bg-blue-500/90 px-4 py-3 text-sm font-semibold text-black shadow-xl hover:brightness-110 disabled:cursor-not-allowed disabled:opacity-50"
                    >
                      Approve USDT
                    </button>

                    <button
                      onClick={handleBuyWithUSDT}
                      disabled={
                        loading ||
                        !isConnected ||
                        isWrongNetwork ||
                        !canProceed ||
                        !hasAllowance ||
                        !batchId
                      }
                      className="w-full rounded-full bg-emerald-500/90 px-4 py-3 text-sm font-semibold text-black shadow-xl hover:brightness-110 disabled:cursor-not-allowed disabled:opacity-50"
                    >
                      Buy with USDT
                    </button>
                  </div>
                );
              })()}
            </>
          )}

          {txStatus && (
            <p className="mt-3 text-[11px] text-amber-100/80">{txStatus}</p>
          )}
        </div>
      </div>

      {/* TX Log */}
      {lastTxHash && (
        <div className="rounded-2xl border border-amber-500/40 bg-black/30 p-4 text-xs text-amber-100/80">
          <div className="flex flex-col gap-1">
            <div className="flex items-start justify-between gap-3">
              <div className="min-w-0">
                <span className="text-amber-200 font-semibold">Last TX:</span>{" "}
                <span className="font-mono break-all">{lastTxHash}</span>
              </div>

              <button
                className="shrink-0 rounded-lg border border-amber-400/40 bg-amber-500/10 px-2 py-1 text-[11px] text-amber-100 hover:bg-amber-500/20"
                onClick={() => navigator.clipboard.writeText(lastTxHash)}
              >
                Copy
              </button>
            </div>
            <div>
              <span className="text-amber-200 font-semibold">Status:</span>{" "}
              {lastTxStatus ?? "-"}
            </div>
            <div>
              <span className="text-amber-200 font-semibold">Block:</span>{" "}
              {lastTxBlock ?? "-"}
            </div>
          </div>
        </div>
      )}

      {/* TABELA: svih 40 batcheva i cene */}
      <div className="rounded-2xl border border-amber-500/40 bg-black/30 p-5 shadow-inner">
        <h3 className="mb-3 text-sm font-semibold text-amber-200">
          Presale Structure – 40 Batches
        </h3>
        <p className="mb-3 text-[11px] text-amber-100/80">
          Svaki batch ima{" "}
          <span className="font-semibold">
            {BATCH_SIZE_DDC.toLocaleString("en-US")} DDC
          </span>
          . Početna cena je{" "}
          <span className="font-semibold">0.01 USDT</span> po DDC, a svaki
          sledeći batch je skuplji za{" "}
          <span className="font-semibold">0.02 USDT</span>.
        </p>
        <div className="overflow-x-auto">
          <table className="min-w-full text-xs text-left text-amber-50/90">
            <thead className="border-b border-amber-500/40 text-[10px] uppercase tracking-wide text-amber-200/80">
              <tr>
                <th className="py-2 pr-4">Batch</th>
                <th className="py-2 pr-4">DDC per batch</th>
                <th className="py-2 pr-4">Price / DDC (USDT)</th>
                <th className="py-2 pr-4">Total raise (USDT)</th>
              </tr>
            </thead>
            <tbody>
              {PRESALE_PLAN.map((b) => {
                const totalRaise = b.priceUSDT * b.supplyDDC;
                return (
                  <tr
                    key={b.id}
                    className="border-b border-amber-500/10 last:border-0"
                  >
                    <td className="py-1.5 pr-4 font-mono text-amber-100">
                      #{b.id}
                    </td>
                    <td className="py-1.5 pr-4">
                      {b.supplyDDC.toLocaleString("en-US")} DDC
                    </td>
                    <td className="py-1.5 pr-4">
                      {b.priceUSDT.toFixed(2)} USDT
                    </td>
                    <td className="py-1.5 pr-4">
                      {totalRaise.toLocaleString("en-US", {
                        maximumFractionDigits: 2,
                      })}{" "}
                      USDT
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    
      <RewardPoolStatus />

      <PresaleFinalizeStatus />
</section>
  );
}
