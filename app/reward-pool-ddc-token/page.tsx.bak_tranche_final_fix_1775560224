'use client';

import { useRewardPoolStatus } from "@/app/hooks/useRewardPoolStatus";

const ADDENDUM_REWARD_POOL = 51_200_000n * 10n ** 18n;
const ADDENDUM_BURN_LOCKED_RESERVE = 51_200_000n * 10n ** 18n;
const ADDENDUM_TOTAL_INITIAL_RESERVE = 102_400_000n * 10n ** 18n;
const ADDENDUM_TOTAL_BURN_TARGET = 128_000_000n * 10n ** 18n;
const ADDENDUM_TRANCHE_SIZE = 32_000_000n * 10n ** 18n;

import { useMemo, useState } from 'react';
import { ethers } from 'ethers';

import presaleArtifact from '@/app/abi/ddcPresaleVesting.json';

function short(a?: string) {
  if (!a) return '-';
  return a.slice(0, 6) + '…' + a.slice(-4);
}

export default function RewardPoolDDCTokenPage() {
  const rpcUrl = process.env.NEXT_PUBLIC_RPC_URL || '';
  const presaleAddr = process.env.NEXT_PUBLIC_PRESALE_ADDRESS || '';

  const provider = useMemo(() => {
    if (!rpcUrl) return null;
    return new ethers.JsonRpcProvider(rpcUrl, undefined, { batchMaxCount: 1, batchStallTime: 0 });
  }, [rpcUrl]);

  const [loading, setLoading] = useState(false);
  const [err, setErr] = useState<string | null>(null);

  const [finalized, setFinalized] = useState<boolean>(false);
  const [totalSold, setTotalSold] = useState<bigint>(0n);
  const [unsoldToRewards, setUnsoldToRewards] = useState<bigint>(0n);
  const rewardPoolState = useRewardPoolStatus();

  async function refresh() {
    setErr(null);
    try {
      if (!provider) throw new Error('RPC URL is missing.');
      if (!presaleAddr) throw new Error('Presale address is missing.');

      const code = await provider.getCode(presaleAddr);
      if (code === '0x') throw new Error('Presale contract not deployed on this network.');

      setLoading(true);

      const c = new ethers.Contract(presaleAddr, (presaleArtifact as any).abi, provider);

      const isFin = await c.finalized();
      setFinalized(Boolean(isFin));

      if (isFin) {
        const sold = await c.finalizedTotalSold();
        const uns = await c.finalizedUnsoldToRewards();
        setTotalSold(BigInt(sold.toString()));
        setUnsoldToRewards(BigInt(uns.toString()));
      } else {
        setTotalSold(0n);
        setUnsoldToRewards(0n);
      }
    } catch (e: any) {
      setErr(String(e?.shortMessage || e?.message || e));
    } finally {
      setLoading(false);
    }
  }

  return (
    <main className="min-h-screen bg-black text-amber-50">
      <div className="mx-auto max-w-5xl px-6 py-10">
        <h1 className="text-2xl font-semibold text-amber-200">Reward Pool DDC Token</h1>
        <p className="mt-2 text-amber-100/70 text-sm">
          Read-only status from Presale view functions (no RPC log scanning).
        </p>

        <div className="mt-6 rounded-2xl border border-amber-500/30 bg-black/35 p-5">
          <div className="flex flex-wrap items-center gap-3">
            <button
              onClick={() => refresh()}
              disabled={loading}
              className="inline-flex items-center justify-center rounded-full border border-amber-500/40 bg-black/40 px-4 py-2 text-sm hover:bg-black/30/40 transition disabled:opacity-50"
            >
              {loading ? 'Loading…' : 'Refresh'}
            </button>
            <div className="text-xs text-amber-100/70">Presale: {presaleAddr ? short(presaleAddr) : '(missing)'}</div>
          </div>

          {err && (
            <div className="mt-4 rounded-xl border border-red-900/60 bg-red-950/30 p-3 text-sm text-red-200">
              {err}
            </div>
          )}

          <div className="mt-6 grid gap-4 md:grid-cols-3">
            <div className="rounded-2xl border border-amber-500/30 bg-black/30 p-4">
              <div className="text-xs uppercase tracking-wider text-amber-100/70">Finalized</div>
              <div className="mt-2 font-mono text-lg">{finalized ? 'YES' : 'NO'}</div>
            </div>
            <div className="rounded-2xl border border-amber-500/30 bg-black/30 p-4">
              <div className="text-xs uppercase tracking-wider text-amber-100/70">Final total sold</div>
              <div className="mt-2 font-mono text-lg">{ethers.formatUnits(totalSold, 18)}</div>
            </div>
            <div className="rounded-2xl border border-amber-500/30 bg-black/30 p-4">
              <div className="text-xs uppercase tracking-wider text-amber-100/70">Final unsold</div>
              <div className="mt-2 font-mono text-lg">{ethers.formatUnits(unsoldToRewards, 18)}</div>

              <div className="mt-4 text-xs uppercase tracking-wider text-amber-100/70">Burn locked</div>
              <div className="mt-2 font-mono text-lg">
                {rewardPoolState.status === "success"
                  ? ethers.formatUnits(rewardPoolState.data.burnLocked, 18)
                  : "-"}
              </div>

              <div className="mt-4 text-xs uppercase tracking-wider text-amber-100/70">Reward Pool available from presale</div>
              <div className="mt-2 font-mono text-lg">
                {rewardPoolState.status === "success"
                  ? ethers.formatUnits(rewardPoolState.data.rewardEligible, 18)
                  : "-"}
              </div>

              <div className="mt-4 text-xs uppercase tracking-wider text-amber-100/70">Reward Pool total balance</div>
              <div className="mt-2 font-mono text-lg">
                {rewardPoolState.status === "success"
                  ? ethers.formatUnits(rewardPoolState.data.totalBalance, 18)
                  : "-"}
              </div>
            </div>
          </div>

          <div className="mt-6 grid gap-4 md:grid-cols-2">
            <div className="rounded-2xl border border-amber-500/30 bg-black/30 p-4">
              <div className="text-xs uppercase tracking-wider text-amber-100/70">Burn Addendum Summary</div>
              <div className="mt-3 space-y-2 text-sm text-amber-50">
                <div className="flex justify-between gap-4">
                  <span className="text-amber-100/70">Reward Pool reserve</span>
                  <span className="font-mono">{ethers.formatUnits(ADDENDUM_REWARD_POOL, 18)}</span>
                </div>
                <div className="flex justify-between gap-4">
                  <span className="text-amber-100/70">Burn Locked reserve</span>
                  <span className="font-mono">{ethers.formatUnits(ADDENDUM_BURN_LOCKED_RESERVE, 18)}</span>
                </div>
                <div className="flex justify-between gap-4">
                  <span className="text-amber-100/70">Total initial reserve</span>
                  <span className="font-mono">{ethers.formatUnits(ADDENDUM_TOTAL_INITIAL_RESERVE, 18)}</span>
                </div>
                <div className="flex justify-between gap-4">
                  <span className="text-amber-100/70">Total burn target</span>
                  <span className="font-mono">{ethers.formatUnits(ADDENDUM_TOTAL_BURN_TARGET, 18)}</span>
                </div>
                <div className="flex justify-between gap-4">
                  <span className="text-amber-100/70">Tranche size</span>
                  <span className="font-mono">{ethers.formatUnits(ADDENDUM_TRANCHE_SIZE, 18)}</span>
                </div>
              </div>
            </div>

            <div className="rounded-2xl border border-amber-500/30 bg-black/30 p-4">
              <div className="text-xs uppercase tracking-wider text-amber-100/70">Tranche schedule</div>
              <div className="mt-3 space-y-2 text-sm text-amber-50">
                <div className="flex justify-between gap-4">
                  <span className="text-amber-100/70">Tranche 1</span>
                  <span className="font-mono">80% burn / 20% validators</span>
                </div>
                <div className="flex justify-between gap-4">
                  <span className="text-amber-100/70">Tranche 2</span>
                  <span className="font-mono">60% burn / 40% validators</span>
                </div>
                <div className="flex justify-between gap-4">
                  <span className="text-amber-100/70">Tranche 3</span>
                  <span className="font-mono">40% burn / 60% validators</span>
                </div>
                <div className="flex justify-between gap-4">
                  <span className="text-amber-100/70">Tranche 4</span>
                  <span className="font-mono">20% burn / 80% validators</span>
                </div>
                <div className="flex justify-between gap-4">
                  <span className="text-amber-100/70">After 128M burned</span>
                  <span className="font-mono">100% fees → validators</span>
                </div>
              </div>
            </div>
          </div>

          <div className="mt-6 rounded-2xl border border-amber-500/30 bg-black/30 p-4">
            <div className="text-xs uppercase tracking-wider text-amber-100/70">Distribution tracking</div>
            <div className="mt-3 space-y-2 text-sm text-amber-50">
              <div className="flex justify-between gap-4">
                <span className="text-amber-100/70">Total distributed to validators</span>
                <span className="font-mono">TODO(WP)</span>
              </div>
              <div className="flex justify-between gap-4">
                <span className="text-amber-100/70">Remaining after validator payouts</span>
                <span className="font-mono">TODO(WP)</span>
              </div>
              <div className="flex justify-between gap-4">
                <span className="text-amber-100/70">Current tranche</span>
                <span className="font-mono">TODO(WP)</span>
              </div>
              <div className="flex justify-between gap-4">
                <span className="text-amber-100/70">Current fee split</span>
                <span className="font-mono">TODO(WP)</span>
              </div>
            </div>
          </div>

          {!finalized && (
            <div className="mt-4 text-xs text-amber-100/70">
              Presale is not finalized yet. Unsold→RewardPool reconciliation is available after Batch 40 / finalize().
            </div>
          )}
        </div>
      </div>
    </main>
  );
}
